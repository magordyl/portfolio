---
const linkedinUrl = 'https://www.linkedin.com/in/dylan-magor-hampel/';
---

<footer
  style="
    border-top: var(--border-1) solid var(--border);
    padding: var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--ink-faint);
  "
>
  <span>© {new Date().getFullYear()} Dylan Magor-Hampel</span>

  <nav aria-label="Footer links" style="display: flex; gap: var(--space-5);">
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      style="color: var(--link); text-decoration: none;"
    >
      LinkedIn
    </a>
    <a href="/privacy" style="color: var(--ink-faint); text-decoration: none;">
      Privacy
    </a>
  </nav>
</footer>
