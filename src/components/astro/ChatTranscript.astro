---
import { getEntry } from 'astro:content';
import { marked } from 'marked';

interface Props {
  id: string;
  mode?: 'inline' | 'breakout';
}

const { id, mode = 'inline' } = Astro.props;

const entry = await getEntry('transcripts', id);
if (!entry) throw new Error(`ChatTranscript: no transcript found with id "${id}"`);

const { title, note, turns: rawTurns } = entry.data;

type Turn = (typeof rawTurns)[number];
type DispRole = 'dylan' | 'claude';
interface Block { role: DispRole; turns: Turn[]; }

// ── Content filters ─────────────────────────────────────────────────────
const RX_COMPACTION   = /^This session is being continued from a previous conversation/i;
const RX_BOOKMARK_CMD = /<command-name>\/bookmark<\/command-name>/i;

function shouldFilter(turn: Turn): boolean {
  const text = turn.text || '';
  if (turn.role === 'user' && RX_COMPACTION.test(text)) return true;
  if (turn.role === 'user' && RX_BOOKMARK_CMD.test(text)) return true;
  return false;
}

// ── Markdown → HTML (build-time) ────────────────────────────────────────
marked.setOptions({ gfm: true, breaks: false });
function md(text: string): string {
  return marked.parse(text || '', { async: false }) as string;
}

function escapeHtml(s: string): string {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function trimTitle(s: string, max = 100): string {
  if (!s) return '';
  s = s.replace(/\s+/g, ' ').trim();
  if (s.length <= max) return s;
  const cut = s.slice(0, max);
  const last = cut.lastIndexOf(' ');
  return (last > 40 ? cut.slice(0, last) : cut).replace(/[.,;:!?-]+$/, '') + '...';
}

// ── Wrap-up split ───────────────────────────────────────────────────────
// Directive sentences ("reply with your answers...", "ready for your review")
// stay visible as a pill outside any expander.
const WRAPUP_RX = /(^|\n\n)([^\n]{0,400}(reply with|answer the|ready for your|once approved|when you(?:'re| are) ready|let me know if|ready to start|ready to proceed|give me the word|give the word|ready for review|your call)[^\n]{0,400})\s*$/i;

function splitWrapup(text: string): { main: string; wrapup: string } {
  if (!text) return { main: '', wrapup: '' };
  const m = text.match(WRAPUP_RX);
  if (!m) return { main: text, wrapup: '' };
  const wrapup = m[2].trim();
  if (wrapup.length > 360) return { main: text, wrapup: '' };
  const main = text.slice(0, text.length - m[0].length).trimEnd();
  return { main, wrapup };
}

function firstHeading(text: string): string {
  if (!text) return '';
  const m = text.match(/^\s*#{1,3}\s+(.+?)\s*$/m);
  return m ? m[1].replace(/[*_`]/g, '').trim() : '';
}

function firstProseLine(text: string): string {
  if (!text) return '';
  const lines = text.split('\n').map((s) => s.trim()).filter(Boolean);
  for (const ln of lines) {
    if (/^[#>*\-]/.test(ln)) continue;
    return ln.replace(/[*_`]/g, '');
  }
  return lines[0] || '';
}

function toolCount(turn: Turn): number {
  return (turn.toolCalls?.length) || (turn.collapsedTools?.length) || 0;
}

function isToolHeavy(turn: Turn): boolean {
  if (toolCount(turn) === 0) return false;
  const text = (turn.text || '').trim();
  return text.length < 600;
}

// ── Cluster heading synthesis ───────────────────────────────────────────
// Merges runs of 3+ consecutive tool-heavy Claude turns into one expander
// with a pattern-matched summary title.
function clusterHeading(runTurns: Turn[]): string {
  // Author override on the first turn of the run wins.
  const override = runTurns[0]?.clusterTitle;
  if (override) return override;

  const totalCalls = runTurns.reduce((n, t) => n + toolCount(t), 0);
  const toolNames = new Set<string>();
  runTurns.forEach((t) => (t.toolCalls || []).forEach((tc) => toolNames.add((tc.name || '').toLowerCase())));
  const collapsedNames = new Set<string>();
  runTurns.forEach((t) => (t.collapsedTools || []).forEach((n) => collapsedNames.add(String(n).toLowerCase())));

  const hasStitch = [...toolNames].some((n) => n.includes('stitch')) ||
                    [...collapsedNames].some((n) => n.includes('stitch'));
  const hasShell  = [...toolNames].some((n) => /bash|powershell/.test(n)) ||
                    [...collapsedNames].some((n) => /bash|powershell/.test(n));

  if (hasStitch && runTurns.length >= 15) {
    return 'Claude used Google Stitch MCP and shell tools to generate all 40 renders across 10 design directions and download the comparison assets';
  }
  if (hasStitch && runTurns.length >= 5) {
    return 'Claude set up the Stitch project and design system, then generated and downloaded the first fidelity render';
  }
  if (hasShell && runTurns.length >= 5) {
    return `Claude ran ${totalCalls} shell and file tools across ${runTurns.length} turns`;
  }
  const first = trimTitle(firstProseLine(runTurns[0].text || ''), 80);
  return `Claude ran ${totalCalls} tool calls across ${runTurns.length} turns - ${first}`;
}

// ── Tool calls ──────────────────────────────────────────────────────────
function renderToolCalls(toolCalls: Turn['toolCalls'], collapsedTools: Turn['collapsedTools']): string {
  if (toolCalls?.length) {
    return '<div class="toolcalls">' + toolCalls.map((tc) => {
      const name = tc.name || '(tool)';
      const input = tc.input ? JSON.stringify(tc.input, null, 2) : '';
      const preview = input ? (input.length > 180 ? input.slice(0, 180) + '...' : input) : '';
      const full = (input && input.length > 180)
        ? `<details class="tc-details"><summary>full input</summary><pre>${escapeHtml(input)}</pre></details>`
        : '';
      return '<div class="toolcall">' +
        `<span class="tc-name">${escapeHtml(name)}</span>` +
        (preview ? `<span class="tc-preview">${escapeHtml(preview)}</span>` : '') +
        full +
        '</div>';
    }).join('') + '</div>';
  }
  if (collapsedTools?.length) {
    return '<div class="toolcalls">' + collapsedTools.map((t) =>
      `<div class="toolcall"><span class="tc-name">${escapeHtml(String(t))}</span></div>`
    ).join('') + '</div>';
  }
  return '';
}

// ── Turn rendering ──────────────────────────────────────────────────────
const ICON_CHEV = '<svg class="chev-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>';

function renderClusterExpander(runTurns: Turn[]): string {
  const totalCalls = runTurns.reduce((n, t) => n + toolCount(t), 0);
  const heading = trimTitle(clusterHeading(runTurns), 140);
  const body = runTurns.map((t) =>
    '<div class="cluster-turn">' +
      md(t.text || '') +
      renderToolCalls(t.toolCalls, t.collapsedTools) +
    '</div>'
  ).join('');

  return '<div class="turn">' +
    '<details class="exp">' +
      '<summary>' +
        '<span class="exp-kind high">cluster</span>' +
        `<span class="exp-title">${escapeHtml(heading)}</span>` +
        `<span class="exp-meta">${totalCalls} calls / ${runTurns.length} turns</span>` +
        `<span class="chevron">${ICON_CHEV}</span>` +
      '</summary>' +
      `<div class="exp-body">${body}</div>` +
    '</details>' +
  '</div>';
}

function renderClaudeTurn(turn: Turn): string {
  const hasKind = !!turn.kind;
  const hasTools = toolCount(turn) > 0;
  const text = turn.text || '';
  const textLen = text.length;
  const { main, wrapup } = splitWrapup(text);
  const isLong = textLen > 500;
  const plain = !hasKind && !hasTools && !isLong;

  if (plain) {
    return '<div class="turn">' +
      `<div class="turn-body">${md(main)}</div>` +
      (wrapup ? `<div class="wrapup">${md(wrapup)}</div>` : '') +
    '</div>';
  }

  const kindLabel = turn.kind || (hasTools ? 'tools' : 'reply');
  const kindClass = hasTools && !turn.kind ? '' : 'high';
  const rawTitle = turn.summary || firstHeading(main) || firstProseLine(main) || 'Claude response';
  const title = trimTitle(rawTitle, 120);
  const meta = hasTools ? `${toolCount(turn)} tool${toolCount(turn) === 1 ? '' : 's'}` : '';
  const defaultOpen = (turn.kind === 'plan' && textLen < 1200);
  const openAttr = defaultOpen ? ' open' : '';
  const body = md(main) + renderToolCalls(turn.toolCalls, turn.collapsedTools);

  return '<div class="turn">' +
    `<details class="exp"${openAttr}>` +
      '<summary>' +
        `<span class="exp-kind ${kindClass}">${escapeHtml(kindLabel)}</span>` +
        `<span class="exp-title">${escapeHtml(title)}</span>` +
        (meta ? `<span class="exp-meta">${escapeHtml(meta)}</span>` : '') +
        `<span class="chevron">${ICON_CHEV}</span>` +
      '</summary>' +
      `<div class="exp-body">${body}</div>` +
    '</details>' +
    (wrapup ? `<div class="wrapup">${md(wrapup)}</div>` : '') +
  '</div>';
}

function renderDylanTurn(turn: Turn): string {
  return `<div class="turn"><div class="turn-body">${md(turn.text || '')}</div></div>`;
}

function renderClaudeTurns(claudeTurns: Turn[]): string {
  const parts: string[] = [];
  let i = 0;
  while (i < claudeTurns.length) {
    let j = i;
    while (j < claudeTurns.length && isToolHeavy(claudeTurns[j])) j++;
    if (j - i >= 3) {
      parts.push(renderClusterExpander(claudeTurns.slice(i, j)));
      i = j;
    } else {
      parts.push(renderClaudeTurn(claudeTurns[i]));
      i++;
    }
  }
  return parts.join('');
}

// ── Build blocks ────────────────────────────────────────────────────────
const turns = rawTurns.filter((t) => !shouldFilter(t));
const blocks: Block[] = [];
for (const turn of turns) {
  const r: DispRole = turn.role === 'user' ? 'dylan' : 'claude';
  const last = blocks[blocks.length - 1];
  if (last && last.role === r) last.turns.push(turn);
  else blocks.push({ role: r, turns: [turn] });
}

const totalTurns = blocks.reduce((n, b) => n + b.turns.length, 0);
const stats = `${totalTurns} turn${totalTurns === 1 ? '' : 's'} / ${blocks.length} block${blocks.length === 1 ? '' : 's'}`;

// Pre-render block HTML strings.
const blockHtml = blocks.map((block) => {
  const turnsHtml = block.role === 'dylan'
    ? block.turns.map(renderDylanTurn).join('')
    : renderClaudeTurns(block.turns);
  return { role: block.role, turnsHtml };
});
---

<section class:list={['chat-transcript', `mode-${mode}`]}>
  <article class="transcript dyl-full exp-flat">
    <header class="t-head">
      <span class="t-title">{title}</span>
      <span class="t-stats">{stats}</span>
    </header>

    {note && <div class="t-note">{note}</div>}

    <div class="blocks">
      {blockHtml.map((block) => (
        <div class={`block block--${block.role}`}>
          <div class="gutter">
            <div class="sender">
              <span class="badge" aria-hidden="true">
                {block.role === 'dylan' ? (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                ) : (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
                )}
              </span>
              <span class="sender-label">{block.role === 'dylan' ? 'Dylan' : 'Claude'}</span>
            </div>
          </div>
          <div class="content" set:html={block.turnsHtml} />
        </div>
      ))}
    </div>
  </article>
</section>

<style>
  .chat-transcript {
    container-type: inline-size;
    margin: var(--space-6) 0;
  }
  .chat-transcript.mode-breakout {
    /* Hook for future case-study layouts to extend past prose column width.
       Styling parity with inline for now. */
  }

  .transcript {
    background:
      linear-gradient(var(--transcript-frame-bg), var(--transcript-frame-bg)) padding-box,
      var(--grad-rv) border-box;
    border: 1px solid transparent;
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-4);
    --hair: var(--border-hairline);
    /* Badge-icon stroke: 2 is required for legibility at the 14px badge
       icon size. The workspace default (1.5) reads as anemic here. Keep
       scoped to this component. */
    --badge-stroke: 2;
  }

  .t-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: var(--text-kicker);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-dim);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border);
  }
  .t-head .t-title { color: var(--ink); }

  .t-note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-dim);
    border-left: 2px solid var(--transcript-chrome-border);
    padding: var(--space-1) 0 var(--space-1) var(--space-3);
    margin-bottom: var(--space-4);
    font-style: italic;
  }

  .blocks { display: flex; flex-direction: column; }

  .block {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: var(--space-2);
    padding: var(--space-4) 0;
  }
  .block + .block { border-top: 1px solid var(--hair); }

  .gutter { display: flex; flex-direction: column; align-items: flex-start; }
  .content { min-width: 0; }

  .sender { display: flex; flex-direction: column; align-items: flex-start; gap: var(--space-1); }

  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .badge :global(svg) {
    width: 14px;
    height: 14px;
    stroke-width: var(--badge-stroke);
  }
  .sender-label {
    font-family: var(--font-mono);
    font-size: var(--text-kicker);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 500;
  }

  .block--dylan .badge {
    background: var(--transcript-dylan-badge-bg);
    color: var(--transcript-dylan-badge-icon);
    border: 1px solid var(--transcript-dylan-badge-border);
  }
  .block--dylan .sender-label { color: var(--transcript-dylan-label); }

  .block--claude .badge {
    background: var(--transcript-claude-badge-bg);
    color: var(--transcript-claude-badge-icon);
    border: 1px solid var(--transcript-claude-badge-border);
  }
  .block--claude .sender-label { color: var(--transcript-claude-label); }

  /* Full-block accent (locked default) */
  .transcript.dyl-full .block--dylan  { border-left: 2px solid var(--transcript-dylan-accent);  padding-left: var(--space-3); }
  .transcript.dyl-full .block--claude { border-left: 2px solid var(--transcript-claude-accent); padding-left: var(--space-3); }

  .content :global(.turn) { min-width: 0; }
  .content :global(.turn + .turn) {
    border-top: 1px solid var(--hair);
    margin-top: var(--space-3);
    padding-top: var(--space-3);
  }

  /* ── Turn-body prose ──────────────────────────────────────────────── */
  .content :global(.turn-body) {
    color: var(--ink);
    font-size: 0.9375rem;
  }
  .content :global(.turn-body p) { margin: 0 0 var(--space-3); }
  .content :global(.turn-body p:last-child) { margin-bottom: 0; }
  .content :global(.turn-body ul),
  .content :global(.turn-body ol) {
    margin: 0 0 var(--space-3);
    padding-left: var(--space-4);
  }
  .content :global(.turn-body li) { margin-bottom: var(--space-1); }
  .content :global(.turn-body strong) { color: var(--ink); font-weight: 600; }
  .content :global(.turn-body em) { color: var(--ink); font-style: italic; }
  .content :global(.turn-body code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--border-hairline);
    color: var(--kicker-default-fg);
    padding: 0.08em 0.35em;
    border-radius: 3px;
  }
  .content :global(.turn-body pre) {
    background: var(--bg);
    border: 1px solid var(--transcript-chrome-border);
    border-radius: 6px;
    padding: var(--space-3) var(--space-4);
    margin: 0 0 var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .content :global(.turn-body pre code) {
    background: none;
    padding: 0;
    color: var(--ink);
  }
  .content :global(.turn-body h1),
  .content :global(.turn-body h2),
  .content :global(.turn-body h3),
  .content :global(.turn-body h4) {
    font-family: var(--font-serif);
    font-weight: 500;
    color: var(--prose-heading-fg);
    letter-spacing: -0.005em;
    margin: var(--space-4) 0 var(--space-2);
  }
  .content :global(.turn-body h1) { font-size: 1.15rem; }
  .content :global(.turn-body h2) { font-size: 1.05rem; }
  .content :global(.turn-body h3) { font-size: 0.98rem; }
  .content :global(.turn-body h4) { font-size: 0.9rem; color: var(--kicker-default-fg); }
  .content :global(.turn-body h1:first-child),
  .content :global(.turn-body h2:first-child),
  .content :global(.turn-body h3:first-child),
  .content :global(.turn-body h4:first-child) { margin-top: 0; }
  .content :global(.turn-body hr) {
    border: none;
    border-top: 1px solid var(--transcript-chrome-border);
    margin: var(--space-4) 0;
  }

  /* ── Wrap-up pill ─────────────────────────────────────────────────── */
  .content :global(.wrapup) {
    margin-top: var(--space-3);
    padding: var(--space-2) var(--space-3);
    background: var(--bg);
    border: 1px solid var(--transcript-chrome-border);
    border-left: 2px solid var(--transcript-wrapup-accent);
    border-radius: 4px;
    font-size: var(--text-sm);
    color: var(--ink);
  }
  .content :global(.wrapup p) { margin: 0; }

  /* ── Expander (flat variant, locked default) ──────────────────────── */
  .content :global(details.exp) {
    background: transparent;
    border: none;
    border-left: 2px solid var(--transcript-chrome-border);
    border-radius: 0;
    padding: var(--space-1) 0 var(--space-1) var(--space-3);
    margin: 0 0 var(--space-2);
  }
  .content :global(details.exp + details.exp) { margin-top: var(--space-2); }
  .content :global(details.exp > summary) {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .content :global(details.exp > summary::-webkit-details-marker) { display: none; }
  .content :global(details.exp[open] > summary) {
    padding-bottom: var(--space-1);
  }
  .content :global(.exp-kind) {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 2px var(--space-2);
    border: 1px solid var(--expander-pill-bg-border);
    border-radius: 3px;
    color: var(--expander-pill-bg-fg);
    flex-shrink: 0;
  }
  .content :global(.exp-kind.high) {
    color: var(--expander-pill-high-fg);
    border-color: var(--expander-pill-high-border);
  }
  .content :global(.exp-title) {
    flex: 1;
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--ink);
    font-size: 0.9rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .content :global(.exp-meta) {
    font-family: var(--font-mono);
    font-size: var(--text-kicker);
    color: var(--ink-faint);
    flex-shrink: 0;
  }
  .content :global(.chevron) {
    display: inline-flex;
    color: var(--ink-faint);
    transition: transform 0.18s ease;
    flex-shrink: 0;
  }
  .content :global(.chev-svg) {
    width: 14px;
    height: 14px;
    stroke-width: var(--badge-stroke);
  }
  .content :global(details.exp[open] > summary .chevron) { transform: rotate(180deg); }
  .content :global(details.exp .exp-body) { padding-top: 2px; }

  /* ── Cluster expander: consecutive tool-heavy turns merged ────────── */
  .content :global(.cluster-turn + .cluster-turn) {
    border-top: 1px solid var(--border-hairline);
    margin-top: var(--space-3);
    padding-top: var(--space-3);
  }

  /* ── Tool calls ───────────────────────────────────────────────────── */
  .content :global(.toolcalls) {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }
  .content :global(.toolcall) {
    padding: var(--space-2) var(--space-3);
    background: var(--bg);
    border: 1px solid var(--transcript-chrome-border);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-dim);
    word-break: break-word;
  }
  .content :global(.toolcall .tc-name) {
    color: var(--kicker-default-fg);
    font-weight: 500;
  }
  .content :global(.toolcall .tc-preview) {
    color: var(--ink-faint);
    display: block;
    margin-top: var(--space-1);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .content :global(details.tc-details) { margin-top: var(--space-1); }
  .content :global(details.tc-details > summary) {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--transcript-fullinput-fg);
    text-decoration: underline;
    text-underline-offset: 3px;
    display: inline-block;
  }
  .content :global(details.tc-details > summary::-webkit-details-marker) { display: none; }
  .content :global(details.tc-details > summary:hover),
  .content :global(details.tc-details[open] > summary) {
    color: var(--transcript-fullinput-fg-hover);
  }
  .content :global(details.tc-details pre) {
    margin-top: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--bg);
    border: 1px solid var(--transcript-chrome-border);
    border-radius: 4px;
    font-size: 0.7rem;
    max-height: 320px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-word;
