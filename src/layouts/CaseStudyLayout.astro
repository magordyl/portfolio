---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, tldr, tags, live, number, started, finished } = project.data;

function fmtDate(d: Date): string {
  return d.toLocaleDateString('en-AU', { month: 'short', year: 'numeric' });
}

const metaParts = [
  `#${String(number).padStart(2, '0')}`,
  `Started ${fmtDate(started)}`,
  finished ? `Shipped ${fmtDate(finished)}` : 'In progress',
];
---

<BaseLayout title={`${title} — Dylan Magor-Hampel`} description={tldr}>
  <article class="case-study">

    <!-- Hero: full-bleed, wider than prose column -->
    <section class="hero">
      <div class="prose-col">
        <p class="project-number">#{String(number).padStart(2, '0')}</p>
        <h1 class="project-title">{title}</h1>
        <p class="project-tldr">{tldr}</p>
        <p class="project-meta">{metaParts.join(' · ')}</p>

        <div class="project-tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>

        {live && (
          <a href={live} target="_blank" rel="noopener noreferrer" class="live-link">
            View live site →
          </a>
        )}
      </div>

      <!-- Hero image placeholder — replaced with <Screenshot> in chunk 5 -->
      <div class="prose-col">
        <div class="hero-image" aria-label="Hero screenshot">
          <span class="hero-image-label">Hero screenshot</span>
        </div>
      </div>
    </section>

    <!-- Body: MDX content in prose column -->
    <div class="prose-col body">
      <slot />
    </div>

  </article>
</BaseLayout>

<style>
  .case-study {
    padding-bottom: var(--space-10);
  }

  /* Prose column: 680px centred, with page gutters */
  .prose-col {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* ── Hero ─────────────────────────────────────────────── */

  .hero {
    padding: var(--space-8) 0 var(--space-7);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-8);
  }

  .project-number {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: var(--ls-caps);
    margin: 0 0 var(--space-3);
  }

  .project-title {
    font-family: var(--font-serif);
    font-size: var(--text-display);
    font-weight: 400;
    letter-spacing: var(--ls-hero);
    line-height: var(--lh-tight);
    color: var(--ink);
    margin: 0 0 var(--space-4);
  }

  .project-tldr {
    font-family: var(--font-sans);
    font-size: var(--text-h4);
    color: var(--ink-dim);
    line-height: var(--lh-normal);
    margin: 0 0 var(--space-4);
  }

  .project-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: 0.04em;
    margin: 0 0 var(--space-4);
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .tag {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--tag-fg);
    background: var(--tag-bg);
    border: 1px solid var(--tag-border);
    border-radius: var(--radius-sm);
    padding: 2px var(--space-2);
  }

  .live-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--link);
    text-decoration: none;
  }

  .live-link:hover {
    color: var(--royal-11);
  }

  .hero-image {
    margin-top: var(--space-6);
    aspect-ratio: 16 / 9;
    background: var(--royal-3);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-image-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--ink-faint);
    letter-spacing: var(--ls-caps);
    text-transform: uppercase;
  }

  /* ── Body ─────────────────────────────────────────────── */

  .body {
    /* Section labels: h2 as mono kicker */
  }

  .body :global(h2) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--ls-caps);
    text-transform: uppercase;
    color: var(--kicker);
    margin: var(--space-8) 0 var(--space-5);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border);
  }

  /* First h2 loses its top border (immediately follows hero) */
  .body :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .body :global(p) {
    font-family: var(--font-sans);
    font-size: var(--text-body);
    color: var(--ink);
    line-height: var(--lh-loose);
    margin: 0 0 var(--space-4);
  }

  .body :global(p:last-child) {
    margin-bottom: 0;
  }

  .body :global(a) {
    color: var(--link);
  }

  .body :global(a:hover) {
    color: var(--royal-11);
  }

  /* Diagram and transcript components get spacing context */
  .body :global(.diagram),
  .body :global(.transcript) {
    margin: var(--space-6) 0;
  }

  /* Transcript breakout: needs space on the right side of page */
  .body :global(.transcript--breakout) {
    /* 120px beyond the prose column right edge */
    margin-right: -120px;
  }

  @media (max-width: 900px) {
    .body :global(.transcript--breakout) {
      margin-right: 0;
    }
  }

  /* Outcome screenshot grid */
  .body :global(.screenshot-grid) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin: var(--space-6) 0;
  }

  @media (max-width: 640px) {
    .body :global(.screenshot-grid) {
      grid-template-columns: 1fr;
    }
  }
</style>
